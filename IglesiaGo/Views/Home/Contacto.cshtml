@{
    ViewData["Title"] = "Contacto";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg p-4">
                <h2 class="text-center fw-bold mb-4">CONTÁCTANOS</h2>
                <form asp-action="EnviarMensaje" method="post">
                    <div class="mb-3">
                        <label class="form-label">Nombre Completo</label>
                        <input type="text" name="NombreRemitente" class="form-control form-control-lg" placeholder="Ej: Jonathan Garay" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="mail" class="form-control" placeholder="nombre@ejemplo.com" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" name="Telefono" class="form-control" placeholder="2664...">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mensaje</label>
                        <textarea name="Mensaje" class="form-control" rows="4" placeholder="¿En qué podemos ayudarte?"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100">ENVIAR MENSAJE</button>
                </form>
            </div>
        </div>
    </div>
</div>