@{
    ViewData["Title"] = "Quiénes Somos";
}

<div class="container my-5 pt-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h1 class="display-4 fw-bold mb-4">NUESTRA <span class="text-primary">VISIÓN</span></h1>
            <p class="lead text-muted">
                Iglesia Go nació con el propósito de conectar a cada persona con la presencia de Dios 
                a través de una experiencia moderna, relevante y profundamente bíblica.
            </p>
            <p>
                Creemos en una iglesia dinámica, donde la tecnología y la fe se unen para 
                llevar el mensaje de salvación a cada rincón de nuestra comunidad en San Luis y el mundo.
            </p>
        </div>
        <div class="col-md-6">
            <img src="https://images.unsplash.com/photo-1544427928-c49cd049c884?q=80&w=1974" class="img-fluid rounded shadow-lg" alt="Nuestra Iglesia">
        </div>
    </div>
</div>