@model IEnumerable<IglesiaGo.Models.Persona>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 gap-2 mt-2">
    <div class="d-flex align-items-center gap-3">
        <h5 class="fw-bold text-secondary m-0">Listado del Personal</h5>
        <button type="button" class="btn btn-sm btn-dark fw-bold" onclick="abrirModalNuevoMiembro()">
            <i class="fa-solid fa-plus me-1"></i> NUEVO MIEMBRO
        </button>
    </div>
    <div class="input-group input-group-sm w-auto">
        <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input type="text" id="tablaBuscador" class="form-control border-start-0" placeholder="Buscar miembro..." onkeyup="buscarMiembro()">
    </div>
</div>

<div class="table-responsive" style="max-height: 520px; overflow-y: auto;">
    <table class="table table-hover align-middle" id="tablaMiembros">
        <thead class="table-light sticky-top">
            <tr>
                <th>Miembro</th>
                <th>DNI</th>
                <th>Contacto</th>
                <th>Función</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var persona in Model)
            {
                // CORRECCIÓN CLAVE: Evaluamos usando el tipo estricto sbyte para que no falle el renderizado del botón
                bool estaActivo = persona.Activo == (sbyte)1;

                <tr data-rol="@persona.TipoPersona" class="@(estaActivo ? "" : "opacity-75 table-light text-muted")">
                    <td>
                        <div class="fw-bold @(estaActivo ? "text-dark" : "text-decoration-line-through text-muted")">
                            @persona.Apellidos, @persona.Nombres
                            @if (!estaActivo)
                            {
                                <span class="badge bg-warning text-dark ms-1" style="font-size: 0.65rem;">INACTIVO</span>
                            }
                        </div>
                        <small class="text-muted">@persona.Ciudad</small>
                    </td>
                    <td>@persona.DocumentoIdentidad</td>
                    <td>
                        <div>@persona.Telefono</div>
                        <small class="text-muted text-truncate d-inline-block" style="max-width: 150px;">@persona.Email</small>
                    </td>
                    <td>
                        <span class="badge @(!estaActivo ? "bg-light text-secondary border" : persona.TipoPersona == "Pastor" ? "bg-danger" : persona.TipoPersona == "Músico" ? "bg-purple text-white" : persona.TipoPersona == "Multimedia" ? "bg-info text-dark" : "bg-secondary")">
                            @persona.TipoPersona
                        </span>
                    </td>
                    <td class="text-end">
                        <button type="button" 
                                onclick="abrirModalEditarMiembro(this)" 
                                class="btn btn-sm btn-outline-primary border-0 me-1" 
                                title="Editar"
                                data-id="@persona.Id"
                                data-nombres="@persona.Nombres"
                                data-apellidos="@persona.Apellidos"
                                data-dni="@persona.DocumentoIdentidad"
                                data-telefono="@persona.Telefono"
                                data-email="@persona.Email"
                                data-ciudad="@persona.Ciudad"
                                data-tipo="@persona.TipoPersona"
                                data-nacimiento="@persona.FechaNacimiento.ToString("yyyy-MM-dd")"
                                data-pais="@persona.Pais">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        
                        @if (estaActivo)
                        {
                            <button type="button" onclick="confirmarCambioEstado(@persona.Id, '@persona.Nombres', false)" class="btn btn-sm btn-outline-warning border-0" title="Desactivar">
                                <i class="fa-solid fa-toggle-on text-success fs-5"></i>
                            </button>
                        }
                        else
                        {
                            <button type="button" onclick="confirmarCambioEstado(@persona.Id, '@persona.Nombres', true)" class="btn btn-sm btn-outline-success border-0" title="Activar">
                                <i class="fa-solid fa-toggle-off text-muted fs-5"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">No hay miembros registrados todavía.</td>
                </tr>
            }
        </tbody>
    </table>
</div>